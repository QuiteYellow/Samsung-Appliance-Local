# Samsung appliance local-API config.
# Copy to `.env` and fill in. Never commit `.env`.

# --- Target appliance ---
# IP of the Samsung appliance on your LAN. Find via your router's DHCP
# lease table (hostname will look like Samsung-Dryer / Samsung-Washer).
APPLIANCE_IP=192.168.1.100

# TCP port the local OCF API listens on. Newer firmware uses a dynamic
# high port — most commonly 49154. Confirm with:
#   nmap -Pn -p 8888,49152-49160 "$APPLIANCE_IP"
# If 8888 is OPEN you have older firmware and this bridge will not work
# (see README).
APPLIANCE_OCF_PORT=49154

# --- Client cert ---
# Privileged client cert + key that authenticates as the SmartThings hub.
# See README "Cert setup" for how to generate these.
# Default paths work for Docker (mounted at /config) and bare-metal
# (./certs). Override only if you keep them elsewhere.
# CERT_PATH=./certs/mega_chain.pem
# KEY_PATH=./certs/mega.key

# --- MQTT broker ---
MQTT_BROKER=192.168.1.5
MQTT_PORT=1883
MQTT_USER=samsung_dryer_bridge
MQTT_PASS=

# Topic prefix for state + commands; HA discovery uses the matching
# device identifier so changing this re-keys the HA device.
MQTT_TOPIC_PREFIX=samsung_dryer

# HA discovery prefix — must match the MQTT integration's setting in HA
# (default `homeassistant`).
HA_DISCOVERY_PREFIX=homeassistant

# Friendly name shown on the HA device card.
DEVICE_NAME=Samsung Dryer

# Bridge timers (seconds).
#   HEALTH_INTERVAL_S    — how often samsung_dryer/bridge/health republishes.
#   HEARTBEAT_INTERVAL_S — periodic full /device/0 reseed for non-observed
#                          resources (firmware, configuration, etc.).
#                          0 disables.
HEALTH_INTERVAL_S=60
HEARTBEAT_INTERVAL_S=600

# Container TZ (passed through to docker-compose).
TZ=Europe/London


# --- Deploy (deploy.sh — rsync + ssh docker compose) ---
# Used only by deploy.sh; ignored by the container.
SSH_HOST=user@your-server
REMOTE_DIR=/mnt/user/appdata/samsung-dryer-bridge
